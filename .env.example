# Real values are set per-environment in Vercel (Preview vs Production scopes) — NOT committed here.
# This file just documents the variables an app expects.

# Browser-exposed config must be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_APP_NAME=App

# Server-only secrets (e.g. a Supabase service key) go in Vercel env vars, never in the repo.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
