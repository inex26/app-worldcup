# Real values are set per-environment in Vercel (Preview vs Production scopes) and
# locally in .env.local (git-ignored). This file just documents what the app expects —
# never commit real values here.

# Supabase project config (browser-exposed → NEXT_PUBLIC_ prefix).
# Find both under: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public canonical origin of this deployment (no trailing slash). Used for the
# landing page's canonical/OG tags, robots.txt and sitemap.xml. Set per Vercel
# environment (Preview vs Production). Falls back to a placeholder if unset.
NEXT_PUBLIC_SITE_URL=
